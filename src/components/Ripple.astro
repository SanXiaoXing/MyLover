---
export interface Props {
  coupleMode?: boolean;
}

const { coupleMode = false } = Astro.props;
---

<div class="absolute inset-0 flex items-center justify-center -z-10 pointer-events-none overflow-visible">
  {coupleMode ? (
    <!-- Couple Mode: Floating Particles / Stars -->
    <div class="particles-container">
      {Array.from({ length: 12 }).map((_, i) => (
        <div 
          class={`star-particle star-${i}`} 
          style={`
            --angle: ${i * 30}deg;
            --distance: ${60 + Math.random() * 80}px;
            --duration: ${3 + Math.random() * 4}s;
            --delay: ${Math.random() * -5}s;
            --size: ${2 + Math.random() * 4}px;
          `}
        ></div>
      ))}
      <div class="ripple-ring-couple absolute rounded-full border border-pink-200/40 opacity-0 ripple-delay-0"></div>
      <div class="ripple-ring-couple absolute rounded-full border border-pink-200/30 opacity-0 ripple-delay-1s"></div>
    </div>
  ) : (
    <!-- Single Mode: Original Ripple -->
    <>
      <div class="ripple-ring absolute rounded-full border border-zinc-200 opacity-0 ripple-delay-0"></div>
      <div class="ripple-ring absolute rounded-full border border-zinc-200 opacity-0 ripple-delay-1s"></div>
      <div class="ripple-ring absolute rounded-full border border-zinc-200 opacity-0 ripple-delay-2s"></div>
    </>
  )}
</div>

<style>
  /* Original Ripple */
  .ripple-ring {
    width: 100%;
    height: 100%;
    animation: ripple 3s linear infinite;
  }
  
  .ripple-delay-1s { animation-delay: 1s; }
  .ripple-delay-2s { animation-delay: 2s; }

  @keyframes ripple {
    0% {
      transform: scale(1);
      opacity: 0.8;
      border-width: 2px;
    }
    100% {
      transform: scale(3.5);
      opacity: 0;
      border-width: 0px;
    }
  }

  /* Couple Mode Ripple */
  .ripple-ring-couple {
    width: 100%;
    height: 100%;
    animation: ripple-couple 4s ease-out infinite;
    box-shadow: 0 0 10px rgba(244, 114, 182, 0.2);
  }

  @keyframes ripple-couple {
    0% {
      transform: scale(1);
      opacity: 0.6;
      border-width: 1.5px;
    }
    100% {
      transform: scale(2.5);
      opacity: 0;
      border-width: 0px;
    }
  }

  /* Star Particles */
  .particles-container {
    position: absolute;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .star-particle {
    position: absolute;
    width: var(--size);
    height: var(--size);
    background: radial-gradient(circle, #fbcfe8 0%, rgba(244,114,182,0.8) 40%, rgba(244,114,182,0) 80%);
    border-radius: 50%;
    filter: drop-shadow(0 0 4px rgba(244, 114, 182, 0.8));
    animation: star-float var(--duration) ease-in-out infinite alternate var(--delay);
    transform: rotate(var(--angle)) translateY(var(--distance)) rotate(calc(var(--angle) * -1));
    opacity: 0.8;
  }

  @keyframes star-float {
    0% {
      transform: rotate(var(--angle)) translateY(var(--distance)) rotate(calc(var(--angle) * -1)) scale(0.5);
      opacity: 0.3;
    }
    50% {
      transform: rotate(calc(var(--angle) + 10deg)) translateY(calc(var(--distance) + 15px)) rotate(calc((var(--angle) + 10deg) * -1)) scale(1.2);
      opacity: 1;
    }
    100% {
      transform: rotate(calc(var(--angle) - 5deg)) translateY(calc(var(--distance) - 10px)) rotate(calc((var(--angle) - 5deg) * -1)) scale(0.8);
      opacity: 0.5;
    }
  }
</style>
