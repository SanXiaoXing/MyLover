---
---

<div class="heartbeat-container relative w-32 md:w-48 h-24 flex items-center justify-center">
  <!-- Ethereal Connection Lines -->
  <svg viewBox="0 0 200 100" class="absolute w-full h-full overflow-visible z-0 sway-svg">
    <defs>
      <linearGradient id="glow-line-1" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="rgba(244,114,182,0)" />
        <stop offset="50%" stop-color="rgba(244,114,182,0.9)" />
        <stop offset="100%" stop-color="rgba(244,114,182,0)" />
      </linearGradient>
      <linearGradient id="glow-line-2" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="rgba(236,72,153,0)" />
        <stop offset="50%" stop-color="rgba(236,72,153,0.7)" />
        <stop offset="100%" stop-color="rgba(236,72,153,0)" />
      </linearGradient>
      <filter id="soft-glow-heavy" x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur stdDeviation="3" result="blur" />
        <feComposite in="SourceGraphic" in2="blur" operator="over" />
      </filter>
    </defs>

    <!-- Faint background tracks -->
    <path d="M 0,50 C 40,10 60,90 100,50 C 140,10 160,90 200,50" fill="none" stroke="rgba(244,114,182,0.15)" stroke-width="1" />
    <path d="M 0,50 C 40,90 60,10 100,50 C 140,90 160,10 200,50" fill="none" stroke="rgba(236,72,153,0.15)" stroke-width="1" />

    <!-- Animated glowing energy beams -->
    <path 
      d="M 0,50 C 40,10 60,90 100,50 C 140,10 160,90 200,50" 
      fill="none" 
      stroke="url(#glow-line-1)" 
      stroke-width="2.5"
      stroke-linecap="round"
      class="wave-line wave-1"
      filter="url(#soft-glow-heavy)"
    />
    
    <path 
      d="M 0,50 C 40,90 60,10 100,50 C 140,90 160,10 200,50" 
      fill="none" 
      stroke="url(#glow-line-2)" 
      stroke-width="2"
      stroke-linecap="round"
      class="wave-line wave-2"
      filter="url(#soft-glow-heavy)"
    />
    
    <!-- Floating Particles (Stars) -->
    <circle cx="60" cy="30" r="1.5" fill="#fbcfe8" class="particle p1" filter="url(#soft-glow-heavy)" />
    <circle cx="140" cy="70" r="2" fill="#f9a8d4" class="particle p2" filter="url(#soft-glow-heavy)" />
    <circle cx="100" cy="15" r="1" fill="#fbcfe8" class="particle p3" filter="url(#soft-glow-heavy)" />
    <circle cx="40" cy="75" r="1.2" fill="#f9a8d4" class="particle p4" filter="url(#soft-glow-heavy)" />
    <circle cx="160" cy="25" r="1.8" fill="#fbcfe8" class="particle p5" filter="url(#soft-glow-heavy)" />
  </svg>
  
  <!-- Organic Heart -->
  <div class="relative z-10 flex items-center justify-center">
     <!-- Outer ripples -->
     <div class="absolute w-12 h-12 rounded-full animate-heart-ripple-1 bg-pink-400/40 blur-[2px]"></div>
     <div class="absolute w-12 h-12 rounded-full animate-heart-ripple-2 bg-pink-500/30 blur-[4px]"></div>
     
     <!-- Inner glowing heart -->
     <div class="animate-organic-beat text-pink-400 drop-shadow-[0_0_12px_rgba(244,114,182,0.9)] relative z-20">
       <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-10 h-10">
         <path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z" />
       </svg>
     </div>
  </div>
</div>

<style>
  .sway-svg {
    animation: sway 6s ease-in-out infinite;
  }
  @keyframes sway {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-5px) scale(1.02); }
  }

  /* Wave flowing animation */
  .wave-line {
    stroke-dasharray: 120 200;
  }
  .wave-1 {
    animation: flow-wave-1 3s linear infinite;
  }
  .wave-2 {
    animation: flow-wave-2 4s linear infinite;
  }

  @keyframes flow-wave-1 {
    0% { stroke-dashoffset: 320; }
    100% { stroke-dashoffset: 0; }
  }
  @keyframes flow-wave-2 {
    0% { stroke-dashoffset: 0; }
    100% { stroke-dashoffset: 320; }
  }

  /* Double-beat organic heart animation */
  .animate-organic-beat {
    animation: organic-beat 1.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) infinite;
    transform-origin: center;
  }

  @keyframes organic-beat {
    0% { transform: scale(1); filter: brightness(1); }
    15% { transform: scale(1.25); filter: brightness(1.1); }
    30% { transform: scale(1); filter: brightness(1); }
    45% { transform: scale(1.15); filter: brightness(1.05); }
    60%, 100% { transform: scale(1); filter: brightness(1); }
  }

  /* Heart ripple effect */
  .animate-heart-ripple-1 {
    animation: heart-ripple 1.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) infinite;
  }
  .animate-heart-ripple-2 {
    animation: heart-ripple 1.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) infinite 0.2s;
  }

  @keyframes heart-ripple {
    0% { transform: scale(0.6); opacity: 0.8; }
    40% { transform: scale(2.2); opacity: 0; }
    100% { transform: scale(2.2); opacity: 0; }
  }

  /* Particles floating */
  .particle {
    transform-origin: center;
  }
  .p1 { animation: float-p 4s ease-in-out infinite; }
  .p2 { animation: float-p 5s ease-in-out infinite 1s; }
  .p3 { animation: float-p 3.5s ease-in-out infinite 0.5s; }
  .p4 { animation: float-p 4.5s ease-in-out infinite 2s; }
  .p5 { animation: float-p 6s ease-in-out infinite 1.5s; }

  @keyframes float-p {
    0%, 100% { transform: translate(0, 0) scale(0.8); opacity: 0.2; }
    25% { transform: translate(6px, -12px) scale(1.2); opacity: 0.8; }
    50% { transform: translate(12px, 0) scale(1); opacity: 0.5; }
    75% { transform: translate(6px, 12px) scale(1.5); opacity: 0.9; }
  }
</style>