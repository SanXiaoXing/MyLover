---
import Layout from '../../layouts/Layout.astro';
import { content, galleryImages } from '../../data/content';

const lang = Astro.url.pathname === '/en/gallery' || Astro.url.pathname.startsWith('/en/') ? 'en' : 'zh';
const currentContent = content[lang as keyof typeof content] || content['zh'];
const { gallery } = currentContent;
---

<Layout title={gallery.title}>
  <main class="w-full min-h-screen pt-32 pb-20 px-6 md:px-12">
    <div class="columns-1 md:columns-2 lg:columns-3 gap-8 space-y-8 max-w-6xl mx-auto">
      {galleryImages.map((src, index) => (
        <div class="gallery-item break-inside-avoid relative group overflow-hidden rounded-lg opacity-0 translate-y-12">
          <img 
            src={src} 
            alt={`Gallery image ${index + 1}`} 
            class="w-full h-auto object-cover grayscale group-hover:grayscale-0 transition-all duration-700 ease-in-out transform group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors duration-500"></div>
        </div>
      ))}
    </div>
  </main>
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const items = document.querySelectorAll('.gallery-item');

  if (items.length > 0) {
    gsap.to(items, {
      opacity: 1,
      y: 0,
      duration: 1.2,
      stagger: 0.15,
      ease: "power3.out",
      delay: 0.5
    });
  }
</script>
