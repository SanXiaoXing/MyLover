---
import Layout from '../layouts/Layout.astro';
import { content } from '../data/content';

const lang = Astro.url.searchParams.get('lang') || 'zh';
const currentContent = content[lang as keyof typeof content] || content['zh'];
const { story } = currentContent;
---

<Layout title={story.title}>
  <main class="w-full min-h-screen pt-32 pb-20 px-6 md:px-12 flex flex-col items-center">
    
    <div class="max-w-3xl w-full relative">
      <!-- Vertical Line -->
      <div class="absolute left-1/2 transform -translate-x-1/2 top-0 bottom-0 w-[1px] bg-zinc-200 origin-top scale-y-0" id="timeline-line"></div>

      <div class="space-y-24 py-12">
        {story.events.map((event, index) => (
          <div class="timeline-item relative flex flex-col items-center text-center opacity-0 translate-y-8">
            <!-- Dot -->
            <div class="w-3 h-3 rounded-full bg-zinc-900 mb-6 z-10 ring-4 ring-white"></div>
            
            <div class="font-display text-3xl md:text-4xl text-zinc-800 mb-2">
              {event.date}
            </div>
            
            <h3 class="font-body font-bold text-lg tracking-widest uppercase text-zinc-500 mb-4">
              {event.title}
            </h3>
            
            <p class="font-body font-light text-zinc-600 max-w-md leading-relaxed">
              {event.description}
            </p>
          </div>
        ))}
      </div>
    </div>

  </main>
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const line = document.getElementById('timeline-line');
  const items = document.querySelectorAll('.timeline-item');

  // Animate Line
  if (line) {
    gsap.to(line, {
      scaleY: 1,
      duration: 1.5,
      ease: "power3.inOut",
      delay: 0.5
    });
  }

  // Animate Items
  if (items.length > 0) {
    gsap.to(items, {
      opacity: 1,
      y: 0,
      duration: 1,
      stagger: 0.4,
      ease: "power3.out",
      delay: 1 // Wait for line to start
    });
  }
</script>
