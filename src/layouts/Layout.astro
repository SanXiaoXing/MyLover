---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Lover - 个人主页" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500;600;700&family=Quicksand:wght@300;400;500;600;700&display=swap" rel="stylesheet">
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-white text-zinc-900 font-sans antialiased overflow-hidden min-h-screen flex flex-col items-center justify-center selection:bg-zinc-200 selection:text-zinc-900">
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--font-display: 'Caveat', cursive;
		--font-body: 'Quicksand', sans-serif;
	}
	html {
		font-family: var(--font-body);
	}
	h1, h2, h3, h4, h5, h6 {
		font-family: var(--font-display);
	}
</style>
