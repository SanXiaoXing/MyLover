---
import Ripple from './Ripple.astro';

interface Props {
  size?: number;
  magneticRange?: number;
  src?: string;
  id?: string;
  coupleMode?: boolean;
}

const { 
  size = 150, 
  magneticRange = 100, 
  src = "https://coresg-normal.trae.ai/api/ide/v1/text_to_image?prompt=minimalist%20avatar%20portrait%20illustration%20simple%20line%20art%20style%20white%20background%20serene%20expression&image_size=square",
  id = 'avatar-default',
  coupleMode = false
} = Astro.props;

const anchorId = `${id}-anchor`;
const movingPartId = `${id}-moving-part`;
---

<div id={anchorId} class="avatar-anchor relative flex items-center justify-center group" data-magnetic-range={magneticRange}>
  
  <div 
    id={movingPartId} 
    class="avatar-moving-part relative z-10 will-change-transform cursor-pointer flex items-center justify-center"
  >
    <!-- Ripple inside moving part so it follows the avatar -->
    <div class="absolute inset-0 z-0 flex items-center justify-center">
        <div style={`width: ${size}px; height: ${size}px; position: relative;`}>
            <Ripple coupleMode={coupleMode} />
        </div>
    </div>

    <!-- Avatar Image -->
    <div class="relative z-10 rounded-full overflow-hidden shadow-sm border-2 border-zinc-50 bg-white hover:shadow-md transition-shadow duration-300" style={`width: ${size}px; height: ${size}px;`}>
      <img 
        src={src} 
        alt="Avatar" 
        class="w-full h-full object-cover"
        width={size}
        height={size}
        loading="eager"
      />
    </div>
  </div>
</div>

<script define:vars={{ anchorId, movingPartId }}>
  const anchor = document.getElementById(anchorId);
  const movingPart = document.getElementById(movingPartId);
  
  if (anchor && movingPart) {
    const range = parseInt(anchor.dataset.magneticRange || '150', 10);
    
    let ticking = false;
    let isHovering = false;

    // Apply initial transition style for smooth return
    movingPart.style.transition = 'transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1)';
    
    const updatePosition = (e) => {
      // Calculate center based on the STATIC anchor
      const rect = anchor.getBoundingClientRect();
      const centerX = rect.left + rect.width / 2;
      const centerY = rect.top + rect.height / 2;
      
      const distanceX = e.clientX - centerX;
      const distanceY = e.clientY - centerY;
      const distance = Math.sqrt(distanceX * distanceX + distanceY * distanceY);

      if (distance < range) {
        if (!isHovering) {
          isHovering = true;
          // When hovering, use a quicker transition for responsiveness
          movingPart.style.transition = 'transform 0.1s ease-out';
        }

        // Magnetic pull strength
        const strength = 0.4; 
        const x = distanceX * strength;
        const y = distanceY * strength;
        
        movingPart.style.transform = `translate(${x}px, ${y}px)`;
      } else {
        if (isHovering) {
          isHovering = false;
          // When leaving (snapping back), use elastic transition
          movingPart.style.transition = 'transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1)';
          movingPart.style.transform = 'translate(0, 0)';
        }
      }
    };

    document.addEventListener('mousemove', (e) => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          updatePosition(e);
          ticking = false;
        });
        ticking = true;
      }
    });
    
    document.addEventListener('mouseleave', () => {
       isHovering = false;
       movingPart.style.transition = 'transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1)';
       movingPart.style.transform = 'translate(0, 0)';
    });
  }
</script>