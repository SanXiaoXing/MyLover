---
import Layout from '../layouts/Layout.astro';
import Avatar from '../components/Avatar.astro';
import LifeTimer from '../components/LifeTimer.astro';
import Heartbeat from '../components/Heartbeat.astro';

const birthDate = '2000-08-02T11:24:00'; 
const loveDate = '2026-02-05T12:23:00'
const showCoupleMode = false; 

// Avatar Images
const avatar1 = "/avatar.png";
const avatar2 = "https://coresg-normal.trae.ai/api/ide/v1/text_to_image?prompt=minimalist%20female%20avatar%20portrait%20illustration%20simple%20line%20art%20style%20white%20background%20serene%20expression&image_size=square";
const singleAvatar = "/avatar.png";
---

<Layout title="Lover">
  <main class="relative w-full h-screen flex flex-col items-center justify-center overflow-hidden opacity-0" id="main-content">
    
    {showCoupleMode ? (
      <div class="relative z-10 transform translate-y-[-10%] flex items-center justify-center gap-4 sm:gap-8 md:gap-12 w-full max-w-4xl px-4">
        <!-- Avatar 1 -->
        <div class="relative flex-shrink-0 avatar-wrapper floating-left">
          <div class="avatar-glow"></div>
          <div class="relative z-10">
            <Avatar size={150} magneticRange={150} src={avatar1} id="avatar-left" coupleMode={true} />
          </div>
        </div>
        
        <!-- Connecting Heartbeat -->
        <div class="flex-shrink-0 opacity-90 scale-110 md:scale-125 text-pink-400 heartbeat-wrapper mt-4">
          <Heartbeat />
        </div>
        
        <!-- Avatar 2 -->
        <div class="relative flex-shrink-0 avatar-wrapper floating-right">
          <div class="avatar-glow"></div>
          <div class="relative z-10">
            <Avatar size={150} magneticRange={150} src={avatar2} id="avatar-right" coupleMode={true} />
          </div>
        </div>
      </div>
    ) : (
      <div class="relative z-10 transform translate-y-[-10%] avatar-wrapper">
        <Avatar size={180} magneticRange={150} src={singleAvatar} id="avatar-single" />
      </div>
    )}

  </main>

  <LifeTimer birthDate={showCoupleMode ? loveDate : birthDate} mode={showCoupleMode ? 'love' : 'life'} />
</Layout>

<script>
  import { gsap } from "gsap";

  const mainContent = document.getElementById('main-content');
  const avatarWrappers = document.querySelectorAll('.avatar-wrapper');
  const heartbeatWrapper = document.querySelector('.heartbeat-wrapper');

  if (mainContent) {
    const tl = gsap.timeline({ defaults: { ease: "power3.out" } });

    tl.to(mainContent, {
      opacity: 1,
      duration: 1.5,
      delay: 0.2
    });

    if (avatarWrappers.length > 0) {
      tl.from(avatarWrappers, {
        y: 30,
        opacity: 0,
        duration: 1.2,
        stagger: 0.2
      }, "-=1.0");
    }

    if (heartbeatWrapper) {
      tl.from(heartbeatWrapper, {
        scale: 0,
        opacity: 0,
        duration: 1,
        ease: "elastic.out(1, 0.5)"
      }, "-=0.8");
    }
  }
</script>

<style>
  .floating-left {
    animation: float 6s ease-in-out infinite;
  }
  .floating-right {
    animation: float 6s ease-in-out infinite;
    animation-delay: -3s;
  }
  @keyframes float {
    0%, 100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-15px);
    }
  }
  .avatar-glow {
    position: absolute;
    inset: -30px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(244,114,182,0.2) 0%, rgba(244,114,182,0.05) 50%, rgba(244,114,182,0) 70%);
    z-index: 0;
    pointer-events: none;
    animation: pulse-glow 4s ease-in-out infinite;
  }
  @keyframes pulse-glow {
    0%, 100% {
      transform: scale(1);
      opacity: 0.8;
    }
    50% {
      transform: scale(1.1);
      opacity: 1;
    }
  }
</style>
