<div class="absolute inset-0 flex items-center justify-center -z-10 pointer-events-none overflow-visible">
  <div class="ripple-ring absolute rounded-full border border-zinc-200 opacity-0 ripple-delay-0"></div>
  <div class="ripple-ring absolute rounded-full border border-zinc-200 opacity-0 ripple-delay-1s"></div>
  <div class="ripple-ring absolute rounded-full border border-zinc-200 opacity-0 ripple-delay-2s"></div>
</div>

<style>
  .ripple-ring {
    width: 100%;
    height: 100%;
    animation: ripple 3s linear infinite;
  }
  
  .ripple-delay-1s { animation-delay: 1s; }
  .ripple-delay-2s { animation-delay: 2s; }

  @keyframes ripple {
    0% {
      transform: scale(1);
      opacity: 0.8;
      border-width: 2px;
    }
    100% {
      transform: scale(3.5);
      opacity: 0;
      border-width: 0px;
    }
  }
</style>
