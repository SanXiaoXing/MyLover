---
interface Props {
  birthDate: string | Date;
  mode?: 'life' | 'love';
}

const { birthDate, mode = 'life' } = Astro.props;
---

<div class="fixed bottom-12 left-0 right-0 text-center select-none pointer-events-none">
  <span 
    id="life-timer" 
    class="font-body text-zinc-400 text-sm tracking-wide opacity-80"
    data-birth-date={new Date(birthDate).toISOString()}
    data-mode={mode}
  >
    <!-- Initial render on server if possible? No, time changes. -->
    计算中...
  </span>
</div>

<script>
  const timerElement = document.getElementById('life-timer');
  
  if (timerElement && timerElement.dataset.birthDate) {
    const startDate = new Date(timerElement.dataset.birthDate);
    const mode = timerElement.dataset.mode || 'life';
    
    const updateTimer = () => {
      const now = new Date();
      const diff = now.getTime() - startDate.getTime();
      
      if (diff > 0) {
        const days = Math.floor(diff / (1000 * 60 * 60 * 24));
        const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        
        // Format based on mode
        if (mode === 'love') {
           timerElement.textContent = `恋爱 ${days} 天 ${hours} 小时 ${minutes} 分`;
        } else {
           timerElement.textContent = `您已经生活了 ${days} 天 ${hours} 小时 ${minutes} 分`;
        }
        timerElement.style.opacity = '1';
      }
    };

    updateTimer();
    setInterval(updateTimer, 10000); 
  }
</script>
